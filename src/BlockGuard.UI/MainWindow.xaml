<Window x:Class="BlockGuard.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:BlockGuard.UI.ViewModels"
        Title="BlockGuard — File Protection Manager"
        Width="1100" Height="720"
        MinWidth="900" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgDarkestBrush}"
        FontFamily="Segoe UI, Arial"
        Foreground="{StaticResource TextPrimaryBrush}">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ============================================================ -->
        <!-- LEFT SIDEBAR                                                   -->
        <!-- ============================================================ -->
        <Border Grid.Column="0"
                Background="{StaticResource SidebarGradient}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- App Logo & Title -->
                <StackPanel Grid.Row="0" Margin="20,24,20,20">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBlock Text="🛡️" FontSize="28" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <StackPanel>
                            <TextBlock Text="BlockGuard" FontSize="20" FontWeight="Bold"
                                       Foreground="White"/>
                            <TextBlock Text="File Protection Manager" FontSize="11"
                                       Foreground="{StaticResource TextMutedBrush}" Margin="0,-2,0,0"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Divider -->
                    <Border Height="1" Background="{StaticResource BorderBrush}" Margin="0,12,0,0"/>
                </StackPanel>

                <!-- Navigation Links -->
                <StackPanel Grid.Row="1" Margin="4,0">
                    <RadioButton Style="{StaticResource NavButton}" IsChecked="True"
                                 Checked="Nav_Dashboard">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📊" FontSize="16" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Dashboard" VerticalAlignment="Center"/>
                        </StackPanel>
                    </RadioButton>

                    <RadioButton Style="{StaticResource NavButton}"
                                 Checked="Nav_ProtectedFiles">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🔒" FontSize="16" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Protected Files" VerticalAlignment="Center"/>
                        </StackPanel>
                    </RadioButton>

                    <RadioButton Style="{StaticResource NavButton}"
                                 Checked="Nav_Activity">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📋" FontSize="16" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Activity Log" VerticalAlignment="Center"/>
                        </StackPanel>
                    </RadioButton>

                    <RadioButton Style="{StaticResource NavButton}"
                                 Checked="Nav_Settings">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⚙️" FontSize="16" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Settings" VerticalAlignment="Center"/>
                        </StackPanel>
                    </RadioButton>
                </StackPanel>

                <!-- Bottom Status -->
                <Border Grid.Row="2" Margin="12,0,12,16"
                        Background="{StaticResource BgCardBrush}"
                        CornerRadius="10" Padding="14,10">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <TextBlock Text="{Binding StatusIcon}" FontSize="12"
                                       VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="{Binding StatusText}" FontSize="12"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Text="{Binding ConfigFilePath}" FontSize="9"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- ============================================================ -->
        <!-- MAIN CONTENT AREA                                              -->
        <!-- ============================================================ -->
        <Border Grid.Column="1" Background="{StaticResource BgDarkBrush}">
            <Grid x:Name="ContentArea">
                <!-- Dashboard Page -->
                <ScrollViewer x:Name="DashboardPage" VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="32,28">
                        <!-- Header -->
                        <TextBlock Text="Dashboard" FontSize="26" FontWeight="Bold" Margin="0,0,0,4"/>
                        <TextBlock Text="Overview of your file protection status"
                                   FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"
                                   Margin="0,0,0,24"/>

                        <!-- Stats Cards -->
                        <WrapPanel Margin="0,0,0,24">
                            <!-- Total Protected -->
                            <Border Background="{StaticResource BgCardBrush}" CornerRadius="12"
                                    Padding="24,20" Margin="0,0,16,16" MinWidth="200">
                                <StackPanel>
                                    <TextBlock Text="🔒  Total Protected" FontSize="12"
                                               Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,8"/>
                                    <TextBlock Text="{Binding TotalProtectedItems}" FontSize="36" FontWeight="Bold">
                                        <TextBlock.Foreground>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                <GradientStop Color="#FF6C63FF" Offset="0"/>
                                                <GradientStop Color="#FF00D2FF" Offset="1"/>
                                            </LinearGradientBrush>
                                        </TextBlock.Foreground>
                                    </TextBlock>
                                    <TextBlock Text="paths guarded" FontSize="11"
                                               Foreground="{StaticResource TextMutedBrush}"/>
                                </StackPanel>
                            </Border>

                            <!-- Files -->
                            <Border Background="{StaticResource BgCardBrush}" CornerRadius="12"
                                    Padding="24,20" Margin="0,0,16,16" MinWidth="200">
                                <StackPanel>
                                    <TextBlock Text="📄  Files" FontSize="12"
                                               Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,8"/>
                                    <TextBlock Text="{Binding TotalProtectedFiles}" FontSize="36" FontWeight="Bold"
                                               Foreground="{StaticResource AccentSecondaryBrush}"/>
                                    <TextBlock Text="individual files" FontSize="11"
                                               Foreground="{StaticResource TextMutedBrush}"/>
                                </StackPanel>
                            </Border>

                            <!-- Folders -->
                            <Border Background="{StaticResource BgCardBrush}" CornerRadius="12"
                                    Padding="24,20" Margin="0,0,16,16" MinWidth="200">
                                <StackPanel>
                                    <TextBlock Text="📁  Folders" FontSize="12"
                                               Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,8"/>
                                    <TextBlock Text="{Binding TotalProtectedFolders}" FontSize="36" FontWeight="Bold"
                                               Foreground="{StaticResource AccentWarningBrush}"/>
                                    <TextBlock Text="directories guarded" FontSize="11"
                                               Foreground="{StaticResource TextMutedBrush}"/>
                                </StackPanel>
                            </Border>

                            <!-- Encryption -->
                            <Border Background="{StaticResource BgCardBrush}" CornerRadius="12"
                                    Padding="24,20" Margin="0,0,16,16" MinWidth="200">
                                <StackPanel>
                                    <TextBlock Text="🔐  Encryption" FontSize="12"
                                               Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,8"/>
                                    <TextBlock FontSize="36" FontWeight="Bold"
                                               Foreground="{StaticResource AccentSuccessBrush}">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="OFF"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding EnableDpapiEncryption}" Value="True">
                                                        <Setter Property="Text" Value="ON"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <TextBlock Text="DPAPI at rest" FontSize="11"
                                               Foreground="{StaticResource TextMutedBrush}"/>
                                </StackPanel>
                            </Border>
                        </WrapPanel>

                        <!-- Quick Actions -->
                        <TextBlock Text="Quick Actions" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12"/>
                        <WrapPanel>
                            <Button Style="{StaticResource PrimaryButton}" Margin="0,0,12,8"
                                    Command="{Binding AddFileCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="📄" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Protect a File" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource PrimaryButton}" Margin="0,0,12,8"
                                    Command="{Binding AddFolderCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="📁" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Protect a Folder" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource GhostButton}" Margin="0,0,12,8"
                                    Command="{Binding SaveCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="💾" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Save Configuration" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </WrapPanel>
                    </StackPanel>
                </ScrollViewer>

                <!-- Protected Files Page -->
                <ScrollViewer x:Name="ProtectedFilesPage" VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Visibility="Collapsed">
                    <StackPanel Margin="32,28">
                        <!-- Header -->
                        <TextBlock Text="Protected Files &amp; Folders" FontSize="26" FontWeight="Bold"
                                   Margin="0,0,0,4"/>
                        <TextBlock Text="Select files and folders to block from AI access"
                                   FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"
                                   Margin="0,0,0,20"/>

                        <!-- Action Buttons -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                            <Button Style="{StaticResource PrimaryButton}" Margin="0,0,12,0"
                                    Command="{Binding AddFileCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="📄  Add File" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource PrimaryButton}" Margin="0,0,12,0"
                                    Command="{Binding AddFolderCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="📁  Add Folder" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource GhostButton}" Margin="0,0,12,0"
                                    Command="{Binding SaveCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="💾  Save Changes" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource GhostButton}"
                                    Command="{Binding RefreshCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🔄  Refresh" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>

                        <!-- Unsaved Changes Banner -->
                        <Border Margin="0,0,0,16" CornerRadius="8" Padding="16,10"
                                Background="#33FFA502">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasUnsavedChanges}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock Foreground="{StaticResource AccentWarningBrush}" FontSize="12">
                                <Run Text="⚠️"/>
                                <Run Text="  You have unsaved changes. Click 'Save Changes' to apply."/>
                            </TextBlock>
                        </Border>

                        <!-- Protected Items List -->
                        <ItemsControl ItemsSource="{Binding ProtectedItems}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,8" CornerRadius="10" Padding="16,14"
                                            Background="{StaticResource BgCardBrush}"
                                            BorderBrush="{StaticResource BorderBrush}"
                                            BorderThickness="1">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsVisible}" Value="False">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Icon -->
                                            <Border Grid.Column="0" Background="{StaticResource BgMediumBrush}"
                                                    CornerRadius="8" Width="44" Height="44"
                                                    Margin="0,0,14,0">
                                                <TextBlock Text="{Binding Icon}" FontSize="22"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                            </Border>

                                            <!-- Info -->
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding FileName}" FontSize="14"
                                                           FontWeight="SemiBold" Foreground="White"/>
                                                <TextBlock Text="{Binding FullPath}" FontSize="11"
                                                           Foreground="{StaticResource TextMutedBrush}"
                                                           TextTrimming="CharacterEllipsis"
                                                           MaxWidth="450" Margin="0,2,0,0"/>
                                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                                    <Border CornerRadius="4" Padding="6,2" Margin="0,0,6,0"
                                                            Background="#22FFFFFF">
                                                        <TextBlock Text="{Binding TypeLabel}" FontSize="10"
                                                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                                                    </Border>
                                                    <Border CornerRadius="4" Padding="6,2" Margin="0,0,6,0"
                                                            Background="#22FFFFFF">
                                                        <TextBlock Text="{Binding Size}" FontSize="10"
                                                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                                                    </Border>
                                                </StackPanel>
                                            </StackPanel>

                                            <!-- Status Badge -->
                                            <Border Grid.Column="2" CornerRadius="6" Padding="10,4"
                                                    Margin="8,0" VerticalAlignment="Center">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="#332ED573"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Exists}" Value="False">
                                                                <Setter Property="Background" Value="#33FF4757"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock FontSize="11" FontWeight="SemiBold">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Text" Value="✓ Protected"/>
                                                            <Setter Property="Foreground"
                                                                    Value="{StaticResource AccentSuccessBrush}"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Exists}" Value="False">
                                                                    <Setter Property="Text" Value="⚠ Missing"/>
                                                                    <Setter Property="Foreground"
                                                                            Value="{StaticResource AccentDangerBrush}"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Border>

                                            <!-- Remove Button -->
                                            <Button Grid.Column="3" Style="{StaticResource DangerButton}"
                                                    Command="{Binding DataContext.RemoveItemCommand,
                                                              RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}"
                                                    VerticalAlignment="Center">
                                                <TextBlock Text="✕  Remove" FontSize="11"/>
                                            </Button>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Empty State -->
                        <Border Margin="0,20,0,0" CornerRadius="12" Padding="40"
                                Background="{StaticResource BgCardBrush}"
                                HorizontalAlignment="Center">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding TotalProtectedItems}" Value="0">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="🔓" FontSize="48" HorizontalAlignment="Center"
                                           Margin="0,0,0,12"/>
                                <TextBlock Text="No Protected Paths" FontSize="18" FontWeight="SemiBold"
                                           HorizontalAlignment="Center" Margin="0,0,0,6"/>
                                <TextBlock Text="Click 'Add File' or 'Add Folder' to start protecting your data from AI access."
                                           FontSize="13" Foreground="{StaticResource TextMutedBrush}"
                                           HorizontalAlignment="Center" TextWrapping="Wrap"
                                           MaxWidth="400" TextAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <!-- Activity Log Page -->
                <ScrollViewer x:Name="ActivityPage" VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Visibility="Collapsed">
                    <StackPanel Margin="32,28">
                        <TextBlock Text="Activity Log" FontSize="26" FontWeight="Bold" Margin="0,0,0,4"/>
                        <TextBlock Text="Recent actions and changes"
                                   FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"
                                   Margin="0,0,0,20"/>

                        <ItemsControl ItemsSource="{Binding RecentActivityItems}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,6" CornerRadius="8" Padding="16,12"
                                            Background="{StaticResource BgCardBrush}"
                                            BorderBrush="{StaticResource BorderBrush}"
                                            BorderThickness="1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="{Binding Action}" FontSize="13"
                                                           FontWeight="SemiBold" Foreground="White"/>
                                                <TextBlock Text="{Binding Detail}" FontSize="11"
                                                           Foreground="{StaticResource TextMutedBrush}"
                                                           TextTrimming="CharacterEllipsis"
                                                           Margin="0,2,0,0"/>
                                            </StackPanel>
                                            <TextBlock Grid.Column="1" Text="{Binding TimeAgo}"
                                                       FontSize="11" VerticalAlignment="Center"
                                                       Foreground="{StaticResource TextMutedBrush}"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>

                <!-- Settings Page -->
                <ScrollViewer x:Name="SettingsPage" VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Visibility="Collapsed">
                    <StackPanel Margin="32,28">
                        <TextBlock Text="Settings" FontSize="26" FontWeight="Bold" Margin="0,0,0,4"/>
                        <TextBlock Text="Agent configuration and preferences"
                                   FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"
                                   Margin="0,0,0,20"/>

                        <!-- Config File Location -->
                        <Border Background="{StaticResource BgCardBrush}" CornerRadius="12"
                                Padding="20" Margin="0,0,0,16">
                            <StackPanel>
                                <TextBlock Text="Configuration File" FontSize="14" FontWeight="SemiBold"
                                           Margin="0,0,0,8"/>
                                <TextBlock Text="{Binding ConfigFilePath}" FontSize="12"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                        <!-- Info Cards -->
                        <Border Background="{StaticResource BgCardBrush}" CornerRadius="12"
                                Padding="20" Margin="0,0,0,16">
                            <StackPanel>
                                <TextBlock Text="About BlockGuard" FontSize="14" FontWeight="SemiBold"
                                           Margin="0,0,0,8"/>
                                <TextBlock FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                                           TextWrapping="Wrap" LineHeight="22">
                                    BlockGuard is a process-based Windows DLP security agent that protects
                                    sensitive files by gating access based on the calling process identity.
                                    It uses a deny-by-default ACL model with real-time ETW monitoring
                                    and DPAPI file encryption at rest.
                                </TextBlock>
                                <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                    <Border Background="#22FFFFFF" CornerRadius="4" Padding="8,4" Margin="0,0,8,0">
                                        <TextBlock Text=".NET 9.0" FontSize="11"
                                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                                    </Border>
                                    <Border Background="#22FFFFFF" CornerRadius="4" Padding="8,4" Margin="0,0,8,0">
                                        <TextBlock Text="Windows Only" FontSize="11"
                                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                                    </Border>
                                    <Border Background="#22FFFFFF" CornerRadius="4" Padding="8,4">
                                        <TextBlock Text="ETW + DPAPI + ACLs" FontSize="11"
                                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                                    </Border>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</Window>
