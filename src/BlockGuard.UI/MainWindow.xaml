<Window x:Class="BlockGuard.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:BlockGuard.UI.ViewModels"
        xmlns:local="clr-namespace:BlockGuard.UI"
        Title="BlockGuard - File Protection Manager"
        Width="1100" Height="720"
        MinWidth="900" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        Background="#FF0D0D1A"
        FontFamily="Segoe UI, Arial"
        Foreground="White">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- LEFT SIDEBAR -->
        <Border Grid.Column="0" BorderThickness="0,0,1,0">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#FF101028" Offset="0"/>
                    <GradientStop Color="#FF0A0A1E" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Border.BorderBrush>
                <SolidColorBrush Color="#FF2A2A55"/>
            </Border.BorderBrush>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- App Logo -->
                <StackPanel Grid.Row="0" Margin="20,24,20,20">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBlock Text="&#x1F6E1;" FontSize="28" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <StackPanel>
                            <TextBlock Text="BlockGuard" FontSize="20" FontWeight="Bold" Foreground="White"/>
                            <TextBlock Text="File Protection Manager" FontSize="11" Foreground="#FF6B6B8D" Margin="0,-2,0,0"/>
                        </StackPanel>
                    </StackPanel>
                    <Border Height="1" Background="#FF2A2A55" Margin="0,12,0,0"/>
                </StackPanel>

                <!-- Navigation -->
                <StackPanel Grid.Row="1" Margin="4,0">
                    <RadioButton x:Name="NavDashboard" GroupName="Nav" IsChecked="True" Checked="Nav_Dashboard"
                                 Style="{StaticResource NavButton}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#x1F4CA;" FontSize="16" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Dashboard" VerticalAlignment="Center"/>
                        </StackPanel>
                    </RadioButton>
                    <RadioButton GroupName="Nav" Checked="Nav_ProtectedFiles" Style="{StaticResource NavButton}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#x1F512;" FontSize="16" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Protected Files" VerticalAlignment="Center"/>
                        </StackPanel>
                    </RadioButton>
                    <RadioButton GroupName="Nav" Checked="Nav_Activity" Style="{StaticResource NavButton}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#x1F4CB;" FontSize="16" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Activity Log" VerticalAlignment="Center"/>
                        </StackPanel>
                    </RadioButton>
                    <RadioButton GroupName="Nav" Checked="Nav_Settings" Style="{StaticResource NavButton}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#x2699;" FontSize="16" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Settings" VerticalAlignment="Center"/>
                        </StackPanel>
                    </RadioButton>
                </StackPanel>

                <!-- Bottom Status -->
                <Border Grid.Row="2" Margin="12,0,12,16" Background="#FF1E1E45" CornerRadius="10" Padding="14,10">
                    <StackPanel>
                        <!-- Agent Toggle Row -->
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Orientation="Horizontal">
                                <TextBlock Text="{Binding StatusIcon}" FontSize="12" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock Text="{Binding StatusText}" FontSize="12" Foreground="#FFB0B0CC" VerticalAlignment="Center"/>
                            </StackPanel>
                            <Button Grid.Column="1" Style="{StaticResource ToggleSwitch}"
                                    Tag="{Binding IsAgentRunning}"
                                    Command="{Binding ToggleAgentCommand}"
                                    IsEnabled="{Binding IsTogglingAgent, Converter={x:Static local:InverseBoolConverter.Instance}}"/>
                        </Grid>
                        <TextBlock Text="{Binding ConfigFilePath}" FontSize="9" Foreground="#FF6B6B8D" TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- MAIN CONTENT AREA -->
        <Border Grid.Column="1" Background="#FF12122B">
            <Grid>
                <!-- ===== DASHBOARD PAGE ===== -->
                <ScrollViewer x:Name="DashboardPage" VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="32,28">
                        <TextBlock Text="Dashboard" FontSize="26" FontWeight="Bold" Margin="0,0,0,4"/>
                        <TextBlock Text="Overview of your file protection status" FontSize="13" Foreground="#FFB0B0CC" Margin="0,0,0,24"/>

                        <!-- Stats Cards Row -->
                        <WrapPanel Margin="0,0,0,24">
                            <Border Background="#FF1E1E45" CornerRadius="12" Padding="24,20" Margin="0,0,16,16" MinWidth="200">
                                <StackPanel>
                                    <TextBlock Text="&#x1F512;  Total Protected" FontSize="12" Foreground="#FF6B6B8D" Margin="0,0,0,8"/>
                                    <TextBlock Text="{Binding TotalProtectedItems}" FontSize="36" FontWeight="Bold">
                                        <TextBlock.Foreground>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                <GradientStop Color="#FF6C63FF" Offset="0"/>
                                                <GradientStop Color="#FF00D2FF" Offset="1"/>
                                            </LinearGradientBrush>
                                        </TextBlock.Foreground>
                                    </TextBlock>
                                    <TextBlock Text="paths guarded" FontSize="11" Foreground="#FF6B6B8D"/>
                                </StackPanel>
                            </Border>
                            <Border Background="#FF1E1E45" CornerRadius="12" Padding="24,20" Margin="0,0,16,16" MinWidth="200">
                                <StackPanel>
                                    <TextBlock Text="&#x1F4C4;  Files" FontSize="12" Foreground="#FF6B6B8D" Margin="0,0,0,8"/>
                                    <TextBlock Text="{Binding TotalProtectedFiles}" FontSize="36" FontWeight="Bold" Foreground="#FF00D2FF"/>
                                    <TextBlock Text="individual files" FontSize="11" Foreground="#FF6B6B8D"/>
                                </StackPanel>
                            </Border>
                            <Border Background="#FF1E1E45" CornerRadius="12" Padding="24,20" Margin="0,0,16,16" MinWidth="200">
                                <StackPanel>
                                    <TextBlock Text="&#x1F4C1;  Folders" FontSize="12" Foreground="#FF6B6B8D" Margin="0,0,0,8"/>
                                    <TextBlock Text="{Binding TotalProtectedFolders}" FontSize="36" FontWeight="Bold" Foreground="#FFFFA502"/>
                                    <TextBlock Text="directories guarded" FontSize="11" Foreground="#FF6B6B8D"/>
                                </StackPanel>
                            </Border>
                            <Border Background="#FF1E1E45" CornerRadius="12" Padding="24,20" Margin="0,0,16,16" MinWidth="200">
                                <StackPanel>
                                    <TextBlock Text="&#x1F510;  Encryption" FontSize="12" Foreground="#FF6B6B8D" Margin="0,0,0,8"/>
                                    <TextBlock Text="DPAPI" FontSize="36" FontWeight="Bold" Foreground="#FF2ED573"/>
                                    <TextBlock Text="at-rest encryption" FontSize="11" Foreground="#FF6B6B8D"/>
                                </StackPanel>
                            </Border>
                        </WrapPanel>

                        <!-- Agent Control Card -->
                        <Border Background="#FF1E1E45" CornerRadius="12" Padding="24,18" Margin="0,0,0,24">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Agent Control" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                    <StackPanel Orientation="Horizontal">
                                        <Ellipse Width="10" Height="10" Margin="0,0,8,0" VerticalAlignment="Center">
                                            <Ellipse.Style>
                                                <Style TargetType="Ellipse">
                                                    <Setter Property="Fill" Value="#FFFF4757"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsAgentRunning}" Value="True">
                                                            <Setter Property="Fill" Value="#FF2ED573"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Ellipse.Style>
                                        </Ellipse>
                                        <TextBlock FontSize="13" Foreground="#FFB0B0CC">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="Agent is stopped"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsAgentRunning}" Value="True">
                                                            <Setter Property="Text" Value="Agent is running and protecting files"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding IsTogglingAgent}" Value="True">
                                                            <Setter Property="Text" Value="Switching..."/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>
                                </StackPanel>
                                <Button Grid.Column="1" Style="{StaticResource ToggleSwitch}"
                                        Tag="{Binding IsAgentRunning}"
                                        Command="{Binding ToggleAgentCommand}"
                                        IsEnabled="{Binding IsTogglingAgent, Converter={x:Static local:InverseBoolConverter.Instance}}"
                                        VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <TextBlock Text="Quick Actions" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12"/>
                        <WrapPanel>
                            <Button Style="{StaticResource PrimaryButton}" Margin="0,0,12,8" Command="{Binding AddFileCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#x1F4C4;" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Protect a File" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource PrimaryButton}" Margin="0,0,12,8" Command="{Binding AddFolderCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#x1F4C1;" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Protect a Folder" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource GhostButton}" Margin="0,0,12,8" Command="{Binding SaveCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#x1F4BE;" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Save Configuration" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </WrapPanel>
                    </StackPanel>
                </ScrollViewer>

                <!-- ===== PROTECTED FILES PAGE ===== -->
                <ScrollViewer x:Name="ProtectedFilesPage" VerticalScrollBarVisibility="Auto" Visibility="Collapsed">
                    <StackPanel Margin="32,28">
                        <TextBlock Text="Protected Files &amp; Folders" FontSize="26" FontWeight="Bold" Margin="0,0,0,4"/>
                        <TextBlock Text="Select files and folders to block from AI access" FontSize="13" Foreground="#FFB0B0CC" Margin="0,0,0,20"/>

                        <!-- Action Buttons -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                            <Button Style="{StaticResource PrimaryButton}" Margin="0,0,12,0" Command="{Binding AddFileCommand}">
                                <TextBlock Text="&#x1F4C4;  Add File"/>
                            </Button>
                            <Button Style="{StaticResource PrimaryButton}" Margin="0,0,12,0" Command="{Binding AddFolderCommand}">
                                <TextBlock Text="&#x1F4C1;  Add Folder"/>
                            </Button>
                            <Button Style="{StaticResource GhostButton}" Margin="0,0,12,0" Command="{Binding SaveCommand}">
                                <TextBlock Text="&#x1F4BE;  Save Changes"/>
                            </Button>
                            <Button Style="{StaticResource GhostButton}" Command="{Binding RefreshCommand}">
                                <TextBlock Text="&#x1F504;  Refresh"/>
                            </Button>
                        </StackPanel>

                        <!-- Protected Items List -->
                        <ItemsControl ItemsSource="{Binding ProtectedItems}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,8" CornerRadius="10" Padding="16,14"
                                            Background="#FF1E1E45" BorderBrush="#FF2A2A55" BorderThickness="1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Icon -->
                                            <Border Grid.Column="0" Background="#FF1A1A3E" CornerRadius="8"
                                                    Width="44" Height="44" Margin="0,0,14,0">
                                                <TextBlock Text="{Binding Icon}" FontSize="22"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>

                                            <!-- Info -->
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding FileName}" FontSize="14" FontWeight="SemiBold" Foreground="White"/>
                                                <TextBlock Text="{Binding FullPath}" FontSize="11" Foreground="#FF6B6B8D"
                                                           TextTrimming="CharacterEllipsis" MaxWidth="450" Margin="0,2,0,0"/>
                                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                                    <Border CornerRadius="4" Padding="6,2" Margin="0,0,6,0" Background="#22FFFFFF">
                                                        <TextBlock Text="{Binding TypeLabel}" FontSize="10" Foreground="#FFB0B0CC"/>
                                                    </Border>
                                                    <Border CornerRadius="4" Padding="6,2" Margin="0,0,6,0" Background="#22FFFFFF">
                                                        <TextBlock Text="{Binding Size}" FontSize="10" Foreground="#FFB0B0CC"/>
                                                    </Border>
                                                </StackPanel>
                                            </StackPanel>

                                            <!-- Status Badge -->
                                            <Border Grid.Column="2" CornerRadius="6" Padding="10,4"
                                                    Margin="8,0" VerticalAlignment="Center" Background="#332ED573">
                                                <TextBlock Text="&#x2713; Protected" FontSize="11" FontWeight="SemiBold" Foreground="#FF2ED573"/>
                                            </Border>

                                            <!-- Remove Button -->
                                            <Button Grid.Column="3" Style="{StaticResource DangerButton}"
                                                    Command="{Binding DataContext.RemoveItemCommand,
                                                              RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}"
                                                    VerticalAlignment="Center">
                                                <TextBlock Text="&#x2715;  Remove" FontSize="11"/>
                                            </Button>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Empty State -->
                        <Border Margin="0,20,0,0" CornerRadius="12" Padding="40" Background="#FF1E1E45" HorizontalAlignment="Center">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding TotalProtectedItems}" Value="0">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="&#x1F513;" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,12"/>
                                <TextBlock Text="No Protected Paths" FontSize="18" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,0,0,6"/>
                                <TextBlock Text="Click 'Add File' or 'Add Folder' to start protecting your data from AI access."
                                           FontSize="13" Foreground="#FF6B6B8D" HorizontalAlignment="Center"
                                           TextWrapping="Wrap" MaxWidth="400" TextAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <!-- ===== ACTIVITY LOG PAGE ===== -->
                <ScrollViewer x:Name="ActivityPage" VerticalScrollBarVisibility="Auto" Visibility="Collapsed">
                    <StackPanel Margin="32,28">
                        <TextBlock Text="Activity Log" FontSize="26" FontWeight="Bold" Margin="0,0,0,4"/>
                        <TextBlock Text="Recent actions and changes" FontSize="13" Foreground="#FFB0B0CC" Margin="0,0,0,20"/>
                        <ItemsControl ItemsSource="{Binding RecentActivityItems}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,6" CornerRadius="8" Padding="16,12"
                                            Background="#FF1E1E45" BorderBrush="#FF2A2A55" BorderThickness="1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="{Binding Action}" FontSize="13" FontWeight="SemiBold" Foreground="White"/>
                                                <TextBlock Text="{Binding Detail}" FontSize="11" Foreground="#FF6B6B8D"
                                                           TextTrimming="CharacterEllipsis" Margin="0,2,0,0"/>
                                            </StackPanel>
                                            <TextBlock Grid.Column="1" Text="{Binding TimeAgo}" FontSize="11"
                                                       VerticalAlignment="Center" Foreground="#FF6B6B8D"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>

                <!-- ===== SETTINGS PAGE ===== -->
                <ScrollViewer x:Name="SettingsPage" VerticalScrollBarVisibility="Auto" Visibility="Collapsed">
                    <StackPanel Margin="32,28">
                        <TextBlock Text="Settings" FontSize="26" FontWeight="Bold" Margin="0,0,0,4"/>
                        <TextBlock Text="Agent configuration and preferences" FontSize="13" Foreground="#FFB0B0CC" Margin="0,0,0,20"/>
                        <Border Background="#FF1E1E45" CornerRadius="12" Padding="20" Margin="0,0,0,16">
                            <StackPanel>
                                <TextBlock Text="Configuration File" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                <TextBlock Text="{Binding ConfigFilePath}" FontSize="12" Foreground="#FFB0B0CC" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                        <Border Background="#FF1E1E45" CornerRadius="12" Padding="20" Margin="0,0,0,16">
                            <StackPanel>
                                <TextBlock Text="About BlockGuard" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                <TextBlock FontSize="12" Foreground="#FFB0B0CC" TextWrapping="Wrap" LineHeight="22">
                                    BlockGuard is a process-based Windows DLP security agent that protects
                                    sensitive files by gating access based on the calling process identity.
                                    It uses a deny-by-default ACL model with real-time ETW monitoring
                                    and DPAPI file encryption at rest.
                                </TextBlock>
                                <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                    <Border Background="#22FFFFFF" CornerRadius="4" Padding="8,4" Margin="0,0,8,0">
                                        <TextBlock Text=".NET 9.0" FontSize="11" Foreground="#FFB0B0CC"/>
                                    </Border>
                                    <Border Background="#22FFFFFF" CornerRadius="4" Padding="8,4" Margin="0,0,8,0">
                                        <TextBlock Text="Windows Only" FontSize="11" Foreground="#FFB0B0CC"/>
                                    </Border>
                                    <Border Background="#22FFFFFF" CornerRadius="4" Padding="8,4">
                                        <TextBlock Text="ETW + DPAPI + ACLs" FontSize="11" Foreground="#FFB0B0CC"/>
                                    </Border>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</Window>
